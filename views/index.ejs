<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — Tesco Vegetable Expiry Tracker</title>
  <link rel="stylesheet" href="/css/main.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
</head>
<body>
<%- include('partials/navbar', { page: 'dashboard' }) %>
<main class="main-content">

  <!-- HERO -->
  <div class="hero-banner">
    <div class="hero-left">
      <div class="hero-live"><span class="live-dot"></span>LIVE BLOCKCHAIN</div>
      <div class="hero-title">Tesco Vegetable Expiry Tracker</div>
      <div class="hero-sub">Every product immutably recorded on Ethereum · Ganache LocalNet</div>
      <div class="hero-clock" id="heroClock"></div>
    </div>
    <div class="hero-right">
      <div class="hero-stat-mini">
        <div class="hsm-val" id="hmTotal">—</div>
        <div class="hsm-lbl">Products On-Chain</div>
      </div>
      <div class="hero-stat-mini">
        <div class="hsm-val" id="hmAlerts">—</div>
        <div class="hsm-lbl">Active Alerts</div>
      </div>
      <button class="btn-refresh" onclick="loadDashboard()">↻ Refresh</button>
    </div>
  </div>

  <!-- STAT CARDS -->
  <div class="stats-grid">
    <div class="stat-card stat-blue">
      <div class="stat-card-icon">📦</div>
      <div class="stat-value" id="statTotal">—</div>
      <div class="stat-label">Total Products</div>
    </div>
    <div class="stat-card stat-green">
      <div class="stat-card-icon">✅</div>
      <div class="stat-value" id="statFresh">—</div>
      <div class="stat-label">Fresh</div>
    </div>
    <div class="stat-card stat-amber">
      <div class="stat-card-icon">⏰</div>
      <div class="stat-value" id="statExpiring">—</div>
      <div class="stat-label">Expiring Soon</div>
    </div>
    <div class="stat-card stat-red">
      <div class="stat-card-icon">❌</div>
      <div class="stat-value" id="statExpired">—</div>
      <div class="stat-label">Expired</div>
    </div>
    <div class="stat-card stat-purple">
      <div class="stat-card-icon">🚨</div>
      <div class="stat-value" id="statRecalled">—</div>
      <div class="stat-label">Recalled</div>
    </div>
  </div>

  <!-- PAYMENT PANEL -->
  <div class="payment-panel">
    <div class="pp-header">
      <span class="pp-title">💰 Supplier Payment System</span>
      <span class="pp-sub">Smart contract auto-pays suppliers when stock is verified</span>
    </div>
    <div class="pp-stats" id="paymentPanel">
      <div class="pp-item"><div class="pp-val">—</div><div class="pp-lbl">Contract Balance</div></div>
      <div class="pp-divider"></div>
      <div class="pp-item"><div class="pp-val pp-paid">—</div><div class="pp-lbl">Total Paid to Suppliers</div></div>
      <div class="pp-divider"></div>
      <div class="pp-item"><div class="pp-val">—</div><div class="pp-lbl">Per Batch Payment</div></div>
    </div>
  </div>

  <!-- STOCK HEALTH BAR -->
  <div class="health-panel">
    <div class="health-header">
      <span class="health-title">Stock Health Overview</span>
      <span class="health-score" id="healthScore">—</span>
    </div>
    <div class="health-bar-track">
      <div class="health-seg seg-fresh"  id="segFresh"   style="width:0%"></div>
      <div class="health-seg seg-expiring" id="segExpiring" style="width:0%"></div>
      <div class="health-seg seg-expired"  id="segExpired"  style="width:0%"></div>
      <div class="health-seg seg-recalled" id="segRecalled" style="width:0%"></div>
    </div>
    <div class="health-legend">
      <span class="hl-dot dot-fresh"></span><span class="hl-lbl">Fresh</span>
      <span class="hl-dot dot-expiring"></span><span class="hl-lbl">Expiring</span>
      <span class="hl-dot dot-expired"></span><span class="hl-lbl">Expired</span>
      <span class="hl-dot dot-recalled"></span><span class="hl-lbl">Recalled</span>
    </div>
  </div>

  <!-- ALERT BANNER -->
  <div id="alertBanner" class="alert-warning hidden"></div>

  <!-- RECENT STOCK -->
  <section class="section">
    <div class="section-header">
      <div>
        <h2>Recent Stock</h2>
        <p class="section-sub">Last 6 products added to blockchain</p>
      </div>
      <a href="/add" class="btn-primary-sm">+ Add Product</a>
    </div>
    <div id="recentGrid" class="product-grid">
      <div class="loading-state">Loading from blockchain…</div>
    </div>
  </section>

  <!-- CATEGORY BREAKDOWN -->
  <section class="section">
    <div class="section-header">
      <div>
        <h2>By Category</h2>
        <p class="section-sub">Stock distribution across vegetable categories</p>
      </div>
    </div>
    <div id="categoryGrid" class="category-grid"></div>
  </section>

</main>
<%- include('partials/footer') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
<script src="/js/web3-utils.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>
