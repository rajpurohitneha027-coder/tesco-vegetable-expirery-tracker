<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ledger — Tesco Vegetable Expiry Tracker</title>
  <link rel="stylesheet" href="/css/main.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
</head>
<body>
<%- include('partials/navbar', { page: 'ledger' }) %>
<main class="main-content">

  <div id="recallModal" class="modal-overlay hidden">
    <div class="modal-box">
      <h3>🚨 Recall Product</h3>
      <p id="recallProductName" class="modal-subtitle"></p>
      <div class="form-group">
        <label>Reason for recall *</label>
        <textarea id="recallReason" rows="3" placeholder="e.g. Contamination risk, quality failure…"></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn-danger" onclick="confirmRecall()">Confirm Recall</button>
        <button class="btn-ghost" onclick="closeRecallModal()">Cancel</button>
      </div>
    </div>
  </div>

  <div class="page-header">
    <div>
      <h1>📋 Blockchain Ledger</h1>
      <p>Immutable on-chain record of all Tesco vegetable stock</p>
    </div>
    <div class="header-actions">
      <div class="filter-bar">
        <button class="filter-btn active" onclick="applyFilter(this,'all')">All</button>
        <button class="filter-btn" onclick="applyFilter(this,'fresh')">✅ Fresh</button>
        <button class="filter-btn" onclick="applyFilter(this,'warning')">⏰ Expiring</button>
        <button class="filter-btn" onclick="applyFilter(this,'expired')">❌ Expired</button>
        <button class="filter-btn" onclick="applyFilter(this,'recalled')">🚨 Recalled</button>
      </div>
      <button class="btn-secondary" onclick="loadLedger()">↻ Refresh</button>
    </div>
  </div>

  <div class="table-container">
    <table class="ledger-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Product</th>
          <th>SKU</th>
          <th>Category</th>
          <th>Harvest</th>
          <th>Expiry</th>
          <th>Time Left</th>
          <th>Status</th>
          <th>Added By</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody id="ledgerBody">
        <tr><td colspan="10" class="loading-cell">Loading from blockchain…</td></tr>
      </tbody>
    </table>
  </div>

  <div class="ledger-footer">
    <span id="ledgerCount"></span>
    <a id="etherscanLink" href="#" target="_blank" class="etherscan-link hidden">🔍 View on Etherscan ↗</a>
  </div>

</main>
<%- include('partials/footer') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
<script src="/js/web3-utils.js"></script>
<script src="/js/ledger.js"></script>
</body>
</html>
